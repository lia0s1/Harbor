    "跨启动保存命令与远程路径历史": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "Save command and remote path history across launches"}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "跨启动保存命令与远程路径历史"}}
      }
    },
    "选择一个 .harbor 备份文件。相同 ID 且连接目标一致的主机将更新；目标不一致时会作为新主机导入。": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "Choose a .harbor backup. A host with the same ID and connection target will be updated; if the target differs, it will be imported as a new host."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "选择一个 .harbor 备份文件。相同 ID 且连接目标一致的主机将更新；目标不一致时会作为新主机导入。"}}
      }
    },
    "远程文件已替换，但无法确认新版本；请刷新后再编辑。": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "The remote file was replaced, but its new version could not be confirmed. Refresh before editing again."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "远程文件已替换，但无法确认新版本；请刷新后再编辑。"}}
      }
    },
    "远程文件已被其他程序修改；为避免覆盖，保存已停止。": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "The remote file was modified by another program. Saving was stopped to prevent overwriting it."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "远程文件已被其他程序修改；为避免覆盖，保存已停止。"}}
      }
    },
    "隐私": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "Privacy"}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "隐私"}}
      }
    },
    "默认关闭。关闭时历史只保留在当前运行内，并会清除 UserDefaults 中已有的命令和远程路径。": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "Off by default. When disabled, history remains only for the current run and existing command and remote path history is removed from UserDefaults."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "默认关闭。关闭时历史只保留在当前运行内，并会清除 UserDefaults 中已有的命令和远程路径。"}}
      }
    },
