    "目录不存在或无权访问：%@": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Directory does not exist or is inaccessible: %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "目录不存在或无权访问：%@"
          }
        }
      }
    },
    "%@ 本地副本保留在：%@": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "%1$@ The local copy was preserved at: %2$@"}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "%@ 本地副本保留在：%@"}}
      }
    },
    "不支持的备份格式版本：%lld": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "Unsupported backup format version: %lld"}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "不支持的备份格式版本：%lld"}}
      }
    },
    "为避免替换符号链接，远程编辑不支持符号链接文件。": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "Remote editing does not support symbolic links, because atomic replacement would replace the link itself."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "为避免替换符号链接，远程编辑不支持符号链接文件。"}}
      }
    },
    "为避免生成无密码保护的私钥，此处不能留空。": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "This field cannot be empty because Harbor will not generate an unprotected private key."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "为避免生成无密码保护的私钥，此处不能留空。"}}
      }
    },
    "主机“%@”包含不安全或不支持的连接参数。": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "Host “%@” contains unsafe or unsupported connection parameters."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "主机“%@”包含不安全或不支持的连接参数。"}}
      }
    },
    "主机密钥未受信任或已变更，Harbor 未发送密码。请先在“终端”中使用交互式 ssh 连接，核对并接受主机指纹后再重试。": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "The host key is not trusted or has changed, so Harbor did not send the password. First connect with interactive ssh in Terminal, verify and accept the fingerprint, then try again."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "主机密钥未受信任或已变更，Harbor 未发送密码。请先在“终端”中使用交互式 ssh 连接，核对并接受主机指纹后再重试。"}}
      }
    },
    "主机：%@:%lld\nHarbor 将严格验证 RDP 证书；证书不受信任或与主机名不匹配时会被拒绝，不会自动忽略自签名证书。": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "Host: %1$@:%2$lld\nHarbor strictly validates the RDP certificate. An untrusted certificate or hostname mismatch will be rejected; self-signed certificates are not ignored automatically."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "主机：%@:%lld\nHarbor 将严格验证 RDP 证书；证书不受信任或与主机名不匹配时会被拒绝，不会自动忽略自签名证书。"}}
      }
    },
    "公钥已安装，但无法验证密钥登录。请先解锁私钥并加入 ssh-agent；如服务器未开启公钥认证，请联系管理员处理。Harbor 不会修改 sshd_config。": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "The public key was installed, but key-based login could not be verified. Unlock the private key and add it to ssh-agent. If public-key authentication is disabled on the server, contact its administrator. Harbor will not modify sshd_config."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "公钥已安装，但无法验证密钥登录。请先解锁私钥并加入 ssh-agent；如服务器未开启公钥认证，请联系管理员处理。Harbor 不会修改 sshd_config。"}}
      }
    },
    "安装公钥并验证登录": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "Install Public Key and Verify Login"}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "安装公钥并验证登录"}}
      }
    },
    "密码保护（必填）": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "Passphrase (required)"}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "密码保护（必填）"}}
      }
    },
    "导入文件包含过多主机或命令。": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "The import contains too many hosts or commands."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "导入文件包含过多主机或命令。"}}
      }
    },
    "导入文件包含重复 ID，已拒绝导入。": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "The import contains duplicate IDs and was rejected."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "导入文件包含重复 ID，已拒绝导入。"}}
      }
    },
    "导入文件过大（上限 16 MB）。": {
