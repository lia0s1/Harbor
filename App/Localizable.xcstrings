        "zh-Hans": {"stringUnit": {"state": "translated", "value": "导入文件过大（上限 16 MB）。"}}
      }
    },
    "操作已取消；远程文件未被替换。": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "The operation was canceled; the remote file was not replaced."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "操作已取消；远程文件未被替换。"}}
      }
    },
    "敏感历史": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "Sensitive History"}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "敏感历史"}}
      }
    },
    "无法准备密钥生成认证助手。": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "Unable to prepare the key-generation authentication helper."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "无法准备密钥生成认证助手。"}}
      }
    },
    "无法读取远程文件版本。": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "Unable to read the remote file version."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "无法读取远程文件版本。"}}
      }
    },
    "未找到可用的本机 SSH 公钥。请先在“设置 → 密钥”生成带密码保护的密钥，或在上方选择已有私钥。": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "No usable local SSH public key was found. First generate a passphrase-protected key in Settings → Keys, or select an existing private key above."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "未找到可用的本机 SSH 公钥。请先在“设置 → 密钥”生成带密码保护的密钥，或在上方选择已有私钥。"}}
      }
    },
    "用于保护私钥": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "Used to protect the private key"}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "用于保护私钥"}}
      }
    },
    "立即清除命令与路径历史": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "Clear Command and Path History Now"}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "立即清除命令与路径历史"}}
      }
    },
    "编辑后的文件超过应用内保存上限（8 MB）。": {
      "extractionState": "manual",
      "localizations": {
