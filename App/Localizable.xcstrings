        "zh-Hans": {"stringUnit": {"state": "translated", "value": "编辑后的文件超过应用内保存上限（8 MB）。"}}
      }
    },
    "请输入当前账户的 SSH 密码。": {
      "extractionState": "manual",
      "localizations": {
        "en": {"stringUnit": {"state": "translated", "value": "Enter the current account's SSH password."}},
        "zh-Hans": {"stringUnit": {"state": "translated", "value": "请输入当前账户的 SSH 密码。"}}
      }
